{
  "name": "metricdemo-metrics",
  "platform_targets": [
    {
      "android": {
        "apps": [
          { "app_id": "ai.bitdrift.metricdemo" }
        ]
      }
    }
  ],
  "flows": [
    {
      "exclusive": {},
      "steps": [
        {
          "match_rule": {
            "match_id": "metric-log",
            "generic_match": {
              "base_matcher": {
                "log_field": "log",
                "operator": "EQUAL",
                "string_value": "metric_values"
              }
            }
          }
        }
      ]
    }
  ],
  "actions": [
    {
      "rule_id": "metrics-chart",
      "metric_chart_rule": {
        "time_series": [
          {
            "average_count": {
              "numerator": { "match_id": "metric-log", "name": "metric_sine" }
            }
          },
          {
            "average_count": {
              "numerator": { "match_id": "metric-log", "name": "metric_square" }
            }
          },
          {
            "average_count": {
              "numerator": { "match_id": "metric-log", "name": "metric_sawtooth" }
            }
          },
          {
            "average_count": {
              "numerator": { "match_id": "metric-log", "name": "metric_triangle" }
            }
          },
          {
            "average_count": {
              "numerator": { "match_id": "metric-log", "name": "metric_dc" }
            }
          }
        ]
      }
    },
    {
      "rule_id": "counter-chart",
      "metric_chart_rule": {
        "time_series": [
          {
            "count": {
              "value": { "match_id": "metric-log", "name": "metric_counter" }
            }
          }
        ]
      }
    },
    {
      "rule_id": "counter-table",
      "metric_chart_rule": {
        "time_series": [
          {
            "count": {
              "value": { "match_id": "metric-log", "name": "metric_counter" }
            }
          }
        ]
      }
    },
    {
      "rule_id": "metrics-table",
      "metric_chart_rule": {
        "time_series": [
          {
            "average_count": {
              "numerator": { "match_id": "metric-log", "name": "metric_sine" }
            }
          },
          {
            "average_count": {
              "numerator": { "match_id": "metric-log", "name": "metric_square" }
            }
          },
          {
            "average_count": {
              "numerator": { "match_id": "metric-log", "name": "metric_sawtooth" }
            }
          },
          {
            "average_count": {
              "numerator": { "match_id": "metric-log", "name": "metric_triangle" }
            }
          },
          {
            "average_count": {
              "numerator": { "match_id": "metric-log", "name": "metric_dc" }
            }
          }
        ]
      }
    }
  ]
}
