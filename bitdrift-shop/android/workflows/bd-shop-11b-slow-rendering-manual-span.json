{
  "name": "bd-shop — Slow Rendering (Recommendations v2) — Manual Span Example",
  "platform_targets": [
    {
      "android": {
        "apps": [
          {
            "app_id": "ai.bitdrift.shop"
          }
        ]
      }
    }
  ],
  "flows": [
    {
      "steps": [
        {
          "match_rule": {
            "match_id": "slow-render-span",
            "generic_match": {
              "and_matcher": {
                "matchers": [
                  {
                    "base_matcher": {
                      "log_field": "_span_name",
                      "operator": "EQUAL",
                      "string_value": "score_products"
                    }
                  },
                  {
                    "base_matcher": {
                      "log_field": "_span_type",
                      "operator": "EQUAL",
                      "string_value": "end"
                    }
                  },
                  {
                    "base_matcher": {
                      "log_field": "_duration_ms",
                      "operator": "GREATER_THAN_OR_EQUAL",
                      "int_value": 16
                    }
                  }
                ]
              }
            }
          }
        }
      ]
    }
  ],
  "actions": [
    {
      "rule_id": "slow-frame-count",
      "metric_chart_rule": {
        "time_series": [
          {
            "count": {
              "value": {
                "match_id": "slow-render-span"
              }
            }
          }
        ]
      }
    },
    {
      "rule_id": "slow-frame-by-recommendations-v2",
      "metric_chart_rule": {
        "time_series": [
          {
            "count": {
              "value": {
                "match_id": "slow-render-span"
              },
              "group_by": {
                "values": [
                  {
                    "state_value": {
                      "scope": "FEATURE_FLAG_EXPOSURE",
                      "key": "recommendations_v2"
                    }
                  }
                ]
              }
            }
          }
        ]
      }
    },
    {
      "rule_id": "slow-frame-duration-histogram",
      "metric_chart_rule": {
        "time_series": [
          {
            "histogram": {
              "value": {
                "match_id": "slow-render-span",
                "name": "_duration_ms"
              },
              "group_by": {
                "values": [
                  {
                    "state_value": {
                      "scope": "FEATURE_FLAG_EXPOSURE",
                      "key": "recommendations_v2"
                    }
                  }
                ]
              }
            }
          }
        ]
      }
    },
    {
      "rule_id": "slow-frame-by-screen",
      "metric_chart_rule": {
        "time_series": [
          {
            "count": {
              "value": {
                "match_id": "slow-render-span"
              },
              "group_by": {
                "values": [
                  {
                    "field_key": "screen_name"
                  }
                ]
              }
            }
          }
        ]
      }
    }
  ]
}
