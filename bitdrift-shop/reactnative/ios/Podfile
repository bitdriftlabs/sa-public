# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

# react-native-screens 3.x is not compatible with the New Architecture.
# Disable it until screens is upgraded to a 4.x version that passes codegen.
ENV['RCT_NEW_ARCH_ENABLED'] = '0'

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ing"
  use_frameworks! :linkage => linkage.to_sym
end

target 'bitdrift-shop' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )

    # fmt 11.x `consteval` is broken with Apple clang 21 (Xcode 26) — patch the
    # version check in base.h so that FMT_USE_CONSTEVAL is disabled.
    fmt_base = "#{config[:reactNativePath]}/../fmt/include/fmt/base.h"
    fmt_base = Dir.glob("#{Pod::Config.instance.installation_root}/Pods/fmt/include/fmt/base.h").first
    if fmt_base && File.exist?(fmt_base)
      content = File.read(fmt_base)
      patched = content.gsub(
        /(__apple_build_version__) < 14000029L/,
        '\1 < 99999999L'
      )
      File.write(fmt_base, patched) if patched != content
    end

    # fmt 11.x uses `consteval` which triggers a false "not a constant expression"
    # error with Apple clang 21 (Xcode 26). Downgrade to `constexpr` for that pod.
    installer.pods_project.targets.each do |target|
      if target.name == 'fmt'
        target.build_configurations.each do |config|
          settings = config.build_settings
          defs = settings['GCC_PREPROCESSOR_DEFINITIONS'] || ['$(inherited)']
          defs = [defs] if defs.is_a?(String)
          defs << 'FMT_USE_CONSTEVAL=0' unless defs.include?('FMT_USE_CONSTEVAL=0')
          settings['GCC_PREPROCESSOR_DEFINITIONS'] = defs
        end
      end
    end
  end
end
